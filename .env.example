ANTHROPIC_API_KEY=your_api_key_here

# Required: signs user login cookies — generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=your_64_char_hex_secret_here

# Required: Supabase PostgreSQL connection string
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@<host>.supabase.com:6543/postgres
