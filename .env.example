ANTHROPIC_API_KEY=your_api_key_here

# Required: signs user login cookies — generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=your_64_char_hex_secret_here

# Required: Supabase PostgreSQL connection string
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@<host>.supabase.com:6543/postgres

# Deployment mode. Set to "production" on your live server.
# In production: AUTH_SECRET is required, TEST_MODE is blocked, cookies use Secure=True.
# Leave unset or set to "development" for local dev and testing.
AI2_ENV=development

# Optional: required in production to access /debug/* endpoints.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Do not commit the real value. Keep this internal-only.
AI2_DEBUG_TOKEN=replace-with-long-random-token

# Feature flags
# Enables DB-backed modular curriculum reads when ready.
# Keep false until migration smoke tests pass.
AI2_MODULAR_CURRICULUM_READS_ENABLED=false

# Render smoke defaults: keep SessionContext-first behavior initially.
AI2_DB_WRITE_THROUGH_ENABLED=false
AI2_TODOS_DB_READS_ENABLED=false
AI2_PROGRESS_DB_READS_ENABLED=false
AI2_USAGE_LIMITS_ENABLED=true

# Test mode must remain off in production.
AI2_TEST_MODE=0
TEST_MODE=0

# LangSmith observability — off by default.
# Set LANGSMITH_TRACING=true and supply a real API key to enable tracing in production.
# Leave LANGSMITH_API_KEY empty locally; tracing is disabled when the key is absent.
# Do not commit real API key values.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai2-render-beta
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
